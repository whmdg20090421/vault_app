name: Build VaultApp APK

on:
  workflow_dispatch:

jobs:
  build:
    runs-on: ubuntu-22.04

    env:
      FORCE_JAVASCRIPT_ACTIONS_TO_NODE24: true
      ACTIONS_STEP_DEBUG: true
      ACTIONS_RUNNER_DEBUG: true

    steps:
      - name: Checkout code
        uses: actions/checkout@v4

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: '3.11'

      - name: Install System Dependencies
        run: |
          sudo apt-get update
          sudo apt-get install -y \
            build-essential git zip unzip openjdk-11-jdk \
            python3-pip autoconf libtool pkg-config \
            zlib1g-dev libssl-dev libffi-dev \
            libncurses5-dev libncursesw5-dev libtinfo-dev \
            cmake libsqlite3-dev libgmp-dev libmpc-dev libmpfr-dev

      - name: Install Rust
        run: |
          curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y --default-toolchain stable
          echo "$HOME/.cargo/bin" >> $GITHUB_PATH

      # 预下载 libffi，带 5 次重试，彻底避免 p4a 编译时 GitHub CDN 504
      - name: Pre-download libffi source
        run: |
          mkdir -p ~/.buildozer/android/packages
          cd ~/.buildozer/android/packages
          for i in 1 2 3 4 5; do
            echo "下载 libffi，第 $i 次尝试..."
            wget -q --timeout=60 \
              "https://github.com/libffi/libffi/archive/v3.4.2.tar.gz" \
              -O "libffi-v3.4.2.tar.gz" && echo "下载成功" && break
            echo "失败，等待 15 秒后重试..."
            sleep 15
          done

      # packages 缓存：用固定 key，下载的源码包不随 spec 变化
      - name: Cache p4a Packages
        uses: actions/cache@v4
        with:
          path: ~/.buildozer/android/packages
          key: p4a-packages-libffi342-stable

      # build 缓存：用 spec hash，编译产物随依赖变化更新
      # 注意：必须在 symlink 等操作之后，防止 cache restore 覆盖手动创建的目录
      - name: Cache Buildozer Build
        uses: actions/cache@v4
        with:
          path: .buildozer
          key: ${{ runner.os }}-buildozer-v5-${{ hashFiles('buildozer.spec') }}
          restore-keys: |
            ${{ runner.os }}-buildozer-v5-

      - name: Build with Buildozer
        env:
          APP_ANDROID_ACCEPT_SDK_LICENSE: 1
          P4A_RELEASE_KEYSTORE: my_release.keystore
          P4A_RELEASE_KEYSTORE_PASSWD: ${{ secrets.KEYSTORE_PASSWORD }}
          P4A_RELEASE_KEYALIAS: ${{ secrets.KEY_ALIAS }}
          P4A_RELEASE_KEYALIAS_PASSWD: ${{ secrets.KEY_PASSWORD }}
        run: |
          echo "${{ secrets.KEYSTORE_B64 }}" | base64 -d > my_release.keystore
          pip install --upgrade buildozer "Cython<3.0.0" virtualenv
          buildozer -v android release 2>&1 | tee build_log.txt
          exit ${PIPESTATUS[0]}

      - name: Upload Build Log on Failure
        if: failure()
        uses: actions/upload-artifact@v4
        with:
          name: build-log-failure
          path: build_log.txt

      - name: Upload P4A Log on Failure
        if: failure()
        uses: actions/upload-artifact@v4
        with:
          name: p4a-log-failure
          path: .buildozer/android/platform/build-arm64-v8a/dists/vaultapp/build.log
          if-no-files-found: ignore

      - name: Upload APK
        if: success()
        uses: actions/upload-artifact@v4
        with:
          name: VaultApp-Signed-APK
          path: bin/*.apk